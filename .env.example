# Hugging Face API Token for AI summaries
# Get yours from: https://huggingface.co/settings/tokens
# Set to 'read' permission (for inference API only)
HF_TOKEN=your_token_here_hf_xxxxx

# Note: Never commit .env file with actual token!
# For local development, copy this to .env and fill in your token
# For Vercel, set HF_TOKEN in Environment Variables section at vercel.com
